# EDINET API
EDINET_API_KEY=

# gBizINFO API
GBIZ_API_TOKEN=

# YouTube Data API v3 (optional)
YOUTUBE_API_KEY=

# ---- AI (Claude 経由、AI SDK v6) ----
# 推奨: Vercel AI Gateway 経由 (failover / OIDC / コスト可視化)
# Vercel 環境では `vercel env pull` で自動的に取得可能。
AI_GATEWAY_API_KEY=

# フォールバック: 直接 Anthropic API。Gateway 未設定時に使用される。
# ローカル開発環境のみ使う場合はこちらだけでも OK。
ANTHROPIC_API_KEY=

# ---- d6e backend ----
# Base URL of the d6e API gateway (Caddy reverse proxy in front of d6e-api).
D6E_API_URL=https://jp-force.d6e.ai

# Workspace ID this app reads/writes against (HQ workspace).
D6E_WORKSPACE_ID=019c94f0-33ea-7392-831a-021b1143f12f

# Dev-only auth. Recommended: provide the refresh token — the app will
# auto-refresh and persist rotations to .next/cache/d6e-dev-tokens.json.
#
# How to obtain:
#   Chrome → https://jp-force.d6e.ai (logged in) → DevTools → Application
#   → Cookies → jp-force.d6e.ai → `auth-refresh` → copy Value
D6E_DEV_REFRESH_TOKEN=

# Optional: initial access token. If omitted the client will bootstrap
# by calling refresh with D6E_DEV_REFRESH_TOKEN. Legacy-only: if set
# without D6E_DEV_REFRESH_TOKEN, the app will fail once it expires.
D6E_DEV_ACCESS_TOKEN=

# ---- Upstash Redis (Vercel Marketplace) ----
# d6e refresh token の回転状態を全 Lambda インスタンス間で共有する
# ため、本番 (Vercel) では Upstash Redis が必須。`vercel integration
# add upstash` で自動プロビジョニングすると、以下の env var が Vercel
# 側に注入される。ローカルでも `vercel env pull .env.local --yes` で
# 同じ Redis を使えば、dev と prod が同じトークン状態を共有できる
# (split-brain 回避)。
#
# これらが両方未設定なら File ベース (.next/cache/d6e-dev-tokens.json)
# にフォールバックする (シングルプロセス dev 用)。
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=
REDIS_URL=

# ---- アプリ認証 (proxy.ts / HTTP Basic Auth) ----
# 全ルートを全世界に公開しないためのゲート。両方未設定ならスキップ
# (ローカル dev 補助)。production では必ず両方セットすること。
# パスワードは 32 文字以上のランダム英数字推奨。
APP_AUTH_USER=
APP_AUTH_PASSWORD=

# ---- ノンネーム資料生成 (d6e STF Docker Runtime) ----
# d6e 側に登録済みの STF バージョン ID (推奨)。設定されていれば
# POST /api/sellers/[id]/nonname はこのバージョンを呼ぶ。
# 登録されたポリシーがそのまま適用されるので本番ではこちら。
D6E_NONNAME_STF_VERSION_ID=

# フォールバック: STF 未登録時に code モードで直接 image を指定する。
# STF_VERSION_ID が優先されるので、両方設定している場合は version が勝つ。
# 開発初期や image の事前動作確認に使う。
# 値は GHCR の実パス (github owner が小文字化された形) を指定する:
#   ghcr.io/<owner-lower>/edinet-ma-nonname:<version>
D6E_NONNAME_IMAGE=ghcr.io/kyoheimiyanishi-max/edinet-ma-nonname:v0.1.0

# ---- AI エンドポイントのレート制限 (optional) ----
# /api/chat, /api/sellers/[id]/ai-buyers, /api/ma-strategy に適用。
# 既定 20 req / 60 sec / 識別子 (Basic Auth ユーザー名 or IP)。
# Upstash Redis が無い環境ではレート制限は効かない (skip)。
AI_RATE_MAX=20
AI_RATE_WINDOW_SEC=60
